# SlipIQ — .env layout (copy to .env and fill values)
# Code reads these via slipiq_env.py — do not rename keys without updating slipiq_env.py
# ─────────────────────────────────────────────────────────────────────────────
# KEY ROLE ASSIGNMENTS (read before adding any new key):
#
#   PROPLINE_API_KEY  → PRIMARY dynamic polling + Pinnacle line source
#                       1,000 credits/day | 20-min intraday scan via slipiq_propline_scanner.py
#                       Budget: ~72 cr/day polling + 200 cr buffer = well under 1k
#
#   PARLAY_API_KEY    → FOUNDATION morning pull (props/F5/consensus/historical/CLV)
#                       1,000 credits/month | ONE pull per endpoint per day
#                       Budget: ~13 cr/day × 30 days = 390/month (610 cr buffer)
#
#   SHARP_API_KEY     → TEST BENCH ONLY — Sharp API (sharpapi.io) built-in EV benchmarking
#                       Never called in main pipeline. Manual/Discord /benchmark only.
#
#   ODDS_API_KEY      → Pinnacle FAILSAFE #1 — fires only when Prop-Line has no Pinnacle data
#                       The Odds API key 1 | used by slipiq_odds_supplement.py
#
#   ODDS_API_2        → Pinnacle FAILSAFE #2 — rotates when ODDS_API_KEY exhausted
#                       The Odds API key 2 | same module, key rotation
#
#   ODDS_API_3        → Pinnacle FAILSAFE #3 — emergency tertiary backup
#                       The Odds API key 3 | never used unless both above are exhausted
#
#   ODDS_PAPI         → Identify this key from your provider dashboard before assigning a role.
#                       If it's a 4th Odds API key: add to ODDS_API_KEYS rotation in slipiq_env.py
#                       If it's a different provider: build a fetch function in slipiq_odds_supplement.py
# ─────────────────────────────────────────────────────────────────────────────

# ─── AI ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_API_CHAT_KEY=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
SLIPIQ_SKIP_AGENTIC=false

# ─── Props / Odds API keys (see role assignments above) ───────────────────────

# PRIMARY — Prop-Line API — 1,000 credits/day — dynamic polling + Pinnacle lines
PROPLINE_API_KEY=

# FOUNDATION — Parlay-API — 1,000 credits/month — morning picks pipeline
PARLAY_API_KEY=

# TEST BENCH — Sharp API (sharpapi.io) — EV benchmarking only — not in main pipeline
SHARP_API_KEY=

# FAILSAFE #1 — The Odds API key 1 — Pinnacle backup when Prop-Line has no Pinnacle data
ODDS_API_KEY=

# FAILSAFE #2 — The Odds API key 2 — rotates when key 1 exhausted
ODDS_API_2=

# FAILSAFE #3 — The Odds API key 3 — emergency backup only
ODDS_API_3=

# UNASSIGNED — Identify this key before using (see role assignments above)
ODDS_PAPI=

ODDS_MAX_EVENTS=15

# ─── Stats / weather ──────────────────────────────────────────────────────────
BDL_API_KEY=
API_FOOTBALL=
TOMORROW_IO_API_KEY=
OPENWEATHER_API_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────
# SUPABASE_URL = project root URL (not /rest/v1/) — code normalizes automatically
SUPABASE_URL=
SUPABASE_KEY=

# ─── Discord ──────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_DAILY_PICKS_CHANNEL=
CHANNEL_TEAM_PARLAY=
CHANNEL_BASKETBALL_PROPS=
DISCORD_LIVE_ALERTS_CHANNEL=
DISCORD_SHARP_REVIEW_CHANNEL=
CHANNEL_SLIPIQ_CHAT=
# PrizePicks intraday entries — defaults to DISCORD_DAILY_PICKS_CHANNEL if not set
DISCORD_PRIZEPICKS_CHANNEL=

# ─── Bankroll ─────────────────────────────────────────────────────────────────
# Used by Kelly sizing in scanner and EV engine
# Set to your actual betting bankroll in dollars
SLIPIQ_BANKROLL=500

# ─── Optional tuning (omit to use defaults in slipiq_env.py) ─────────────────
# SLIP_CHAT_MIN_CONF=65
# SLIP_CHAT_MIN_EV=0.02
# SLIP_CHAT_SESSION_TTL_MIN=30
# SLIP_CHAT_USER_COOLDOWN_SEC=10
# SLIPIQ_PARLAY_MIN_CONF=68
# SLIPIQ_PARLAY_MIN_BOOKS=2
# SLIPIQ_PARLAY_MAX_MENU=12
# SLIPIQ_PARLAY_MAX_SLIP=6
