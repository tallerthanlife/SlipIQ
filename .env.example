# SlipIQ — .env layout (copy to .env and fill values)
# Code reads these via slipiq_env.py — do not rename keys without updating slipiq_env.py

# AI
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
SLIPIQ_SKIP_AGENTIC=false

# Props primary + odds failsafe chain (architecture diagram)
PARLAY_API_KEY=
ODDS_API_KEY=
ODDS_API_2=
ODDS_API_3=
ODDS_PAPI=
SHARP_API_KEY=
ODDS_MAX_EVENTS=15

# Stats / weather
BDL_API_KEY=
API_FOOTBALL=
TOMORROW_IO_API_KEY=
OPENWEATHER_API_KEY=

# Database (SUPABASE_URL = project root, not /rest/v1/ — code normalizes if needed)
SUPABASE_URL=
SUPABASE_KEY=

# Discord
DISCORD_BOT_TOKEN=
DISCORD_DAILY_PICKS_CHANNEL=
CHANNEL_TEAM_PARLAY=
CHANNEL_BASKETBALL_PROPS=
DISCORD_LIVE_ALERTS_CHANNEL=
DISCORD_SHARP_REVIEW_CHANNEL=
CHANNEL_SLIPIQ_CHAT=

